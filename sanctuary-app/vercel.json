{
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    { "source": "/status", "destination": "/app.py" },
    { "source": "/save-data", "destination": "/app.py" },
    { "source": "/get-sync", "destination": "/app.py" },
    { "source": "/webhook", "destination": "/app.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
